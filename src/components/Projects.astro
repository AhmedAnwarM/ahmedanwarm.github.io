---
// TODO: Replace with real projects. NDA? Describe the architecture and impact
// without naming the client — what you built matters more than who for.
const projects = [
  {
    label: 'Enterprise Platform',
    title: 'Event-Driven Integration Platform',  // TODO
    description:
      'Designed and led delivery of a high-throughput integration platform for a [financial services / telco / retail] enterprise, processing X million events daily across Y downstream systems. Introduced domain-driven boundaries and a canonical event schema that reduced cross-team integration incidents by Z%.', // TODO
    stack: ['Java', 'Kafka', 'Kubernetes', 'PostgreSQL', 'Spring Boot'],  // TODO
    link: null,      // TODO: add GitHub or case-study link if available
    featured: true,
  },
  {
    label: 'Architecture Modernisation',
    title: 'Legacy Monolith → Microservices',    // TODO
    description:
      'Architected the incremental strangler-fig migration of a monolithic ERP-style application to independently deployable services. Defined service boundaries, data ownership, and deployment topology. The resulting system halved mean time to deploy and enabled independent team scaling.', // TODO
    stack: ['Domain-Driven Design', 'Docker', 'API Gateway', 'PostgreSQL', 'CI/CD'],  // TODO
    link: null,
    featured: true,
  },
  {
    label: 'Internal Tooling',
    title: 'Engineering Enablement Platform',    // TODO
    description:
      'Built an internal developer platform that standardised CI/CD templates, infrastructure provisioning, and observability across X squads. Reduced new-project setup from 2 weeks to under a day and cut cross-team configuration drift.', // TODO
    stack: ['Terraform', 'GitHub Actions', 'Kubernetes', 'Grafana', 'Prometheus'],  // TODO
    link: null,
    featured: false,
  },
  {
    label: 'Open Source / Side Project',
    title: 'Your Project Here',                  // TODO
    description:
      'Add a personal project, open-source contribution, or architectural proof-of-concept here.', // TODO
    stack: ['Your', 'Stack', 'Here'],            // TODO
    link: 'https://github.com/AhmedAnwarM',      // TODO
    featured: false,
  },
];
---

<section id="projects" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">

    <!-- Section header -->
    <div class="reveal mb-16">
      <p class="font-mono text-[color:var(--color-accent)] text-sm tracking-widest mb-2">04. projects</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-[color:var(--color-heading)]">
        Things I've Built
      </h2>
      <div class="mt-4 h-px w-24 bg-gradient-to-r from-[color:var(--color-accent)] to-transparent"></div>
      <p class="mt-6 max-w-xl text-[color:var(--color-muted)] text-sm leading-relaxed">
        A selection of systems and platforms I've designed and delivered — some under NDA,
        described in terms of architecture and outcomes rather than client names.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid sm:grid-cols-2 gap-6">
      {
        projects.map((project, i) => (
          <div class={`reveal reveal-delay-${(i % 2) + 1} project-card flex flex-col`}>
            <!-- Top row -->
            <div class="flex items-start justify-between mb-4">
              <span class="font-mono text-[10px] text-[color:var(--color-accent)] tracking-widest uppercase">
                {project.label}
              </span>
              <div class="flex gap-3 text-[color:var(--color-muted)]">
                {/* Folder icon */}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="text-[color:var(--color-accent)]">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" />
                </svg>
                {project.link && (
                  <a
                    href={project.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`View ${project.title}`}
                    class="hover:text-[color:var(--color-accent)] transition-colors"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </a>
                )}
              </div>
            </div>

            <!-- Title -->
            <h3 class="text-lg font-semibold text-[color:var(--color-heading)] mb-3">
              {project.title}
            </h3>

            <!-- Description -->
            <p class="text-[color:var(--color-muted)] text-sm leading-relaxed flex-1 mb-6">
              {project.description}
            </p>

            <!-- Stack -->
            <div class="flex flex-wrap gap-2">
              {project.stack.map((tech) => (
                <span class="skill-tag">{tech}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <!-- GitHub CTA -->
    <div class="reveal mt-14 text-center">
      <a
        href="https://github.com/AhmedAnwarM"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 font-mono text-sm text-[color:var(--color-muted)] hover:text-[color:var(--color-accent)] transition-colors group"
      >
        View more on GitHub
        <span class="group-hover:translate-x-1 transition-transform">→</span>
      </a>
    </div>
  </div>
</section>
