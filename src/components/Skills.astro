---

<section id="skills" class="py-24 px-6 bg-[color:var(--color-surface)]">
  <div class="max-w-6xl mx-auto">

    <!-- Section header -->
    <div class="reveal mb-16">
      <p class="font-mono text-[color:var(--color-accent)] text-sm tracking-widest mb-2">03. expertise</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-[color:var(--color-heading)]">
        What I Work With
      </h2>
      <div class="mt-4 h-px w-24 bg-gradient-to-r from-[color:var(--color-accent)] to-transparent"></div>
    </div>

    <!-- Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        categories.map((cat, i) => (
          <div
            class={`reveal reveal-delay-${(i % 3) + 1} p-6 rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-elevated)] hover:border-[rgba(56,189,248,0.3)] transition-colors duration-200`}
          >
            <div class="flex items-center gap-3 mb-5">
              <span class="text-[color:var(--color-accent)]" set:html={cat.icon} />
              <h3 class="font-semibold text-[color:var(--color-heading)] text-sm">{cat.title}</h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {cat.skills.map((skill) => (
                <span class="skill-tag">{skill}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
