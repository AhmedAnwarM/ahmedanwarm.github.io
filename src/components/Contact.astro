  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/AhmedAnwarM',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: 'GitHub',
    href: 'https://github.com/AhmedAnwarM',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  },
  {
    label: 'Email',
    href: 'mailto:ahmedanwarm@outlook.com',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
];
---

<section id="contact" class="py-32 px-6 bg-[color:var(--color-surface)]">
  <div class="max-w-2xl mx-auto text-center">

    <!-- Section label -->
    <p class="reveal font-mono text-[color:var(--color-accent)] text-sm tracking-widest mb-4">05. contact</p>

    <!-- Heading -->
    <h2 class="reveal reveal-delay-1 text-4xl sm:text-5xl font-bold text-[color:var(--color-heading)] mb-6">
      Let's Talk
    </h2>

    <!-- Message -->
    <p class="reveal reveal-delay-2 text-[color:var(--color-body)] text-lg leading-relaxed mb-10 max-w-lg mx-auto">
      Whether you're exploring architectural collaboration, a speaking engagement,
      consulting, or simply want to connect — my inbox is open.
    </p>

    <!-- Primary CTA -->
    <div class="reveal reveal-delay-3 mb-14">
      <a
        href="mailto:ahmedanwarm@outlook.com"
        class="inline-flex items-center gap-3 px-8 py-4 bg-[color:var(--color-accent)] text-[color:var(--color-bg)] font-semibold text-sm rounded-lg hover:opacity-85 transition-opacity font-mono"
      >
        Say Hello
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>

    <!-- Social icons — min 44×44 touch target via padding -->
    <div class="reveal reveal-delay-4 flex justify-center gap-2">
      {
        socials.map(({ label, href, icon }) => (
          <a
            href={href}
            target={href.startsWith('mailto') ? undefined : '_blank'}
            rel={href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
            aria-label={label}
            class="inline-flex items-center justify-center w-11 h-11 rounded-lg text-[color:var(--color-muted)] hover:text-[color:var(--color-accent)] hover:bg-[rgba(56,189,248,0.08)] hover:-translate-y-0.5 transition-all duration-200"
            set:html={icon}
          />
        ))
      }
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="py-8 px-6 text-center border-t border-[color:var(--color-line)]">
  <p class="font-mono text-xs text-[color:var(--color-muted)]">
    Designed & built by Ahmed Anwar
  </p>
</footer>
